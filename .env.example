# DevAutoPilot v2 — environment configuration (placeholders only, no real secrets)
# Copy this file to .env and fill in values. NEVER commit a real .env.

# ---- LLM providers ----
# OpenAI (embeddings / fallback codegen)
OPENAI_API_KEY=

# Azure OpenAI (heavy reasoning — RCA, patch synthesis)
AZURE_OPENAI_ENDPOINT=
AZURE_OPENAI_API_KEY=
AZURE_OPENAI_API_VERSION=2024-12-01-preview
# Azure routes by DEPLOYMENT NAME (what you named the model in Azure), not model id.
AZURE_OPENAI_DEPLOYMENT=

# Google Gemini Flash (free cloud reasoning path)
GEMINI_API_KEY=

# Ollama (local LLM path — default in dev)
OLLAMA_BASE_URL=http://localhost:11434

# ---- LLM routing (which model the agents actually use) ----
# Provider the agents use: ollama | openai | azure | gemini
LLM_DEFAULT_PROVIDER=ollama
# Local model when provider=ollama (e.g. llama3.1, phi4)
OLLAMA_MODEL=llama3.1
# Cloud model when provider=openai/azure/gemini (e.g. gpt-5-mini, gpt-4o-mini)
LLM_CLOUD_MODEL=gpt-5-mini
# To use standard OpenAI (api.openai.com):
#   LLM_DEFAULT_PROVIDER=openai
#   OPENAI_API_KEY=sk-...        (.env is gitignored, never committed)
#   LLM_CLOUD_MODEL=gpt-5-mini
# To use AZURE OpenAI (azure_endpoint + deployment name):
#   LLM_DEFAULT_PROVIDER=azure
#   AZURE_OPENAI_ENDPOINT=https://<resource>.cognitiveservices.azure.com/
#   AZURE_OPENAI_API_KEY=<your key>
#   AZURE_OPENAI_DEPLOYMENT=<your deployment name>   # e.g. gpt-5-mini

# ---- Data layer ----
# PostgreSQL (async asyncpg driver)
DATABASE_URL=postgresql+asyncpg://devautopilot:devautopilot@localhost:5432/devautopilot

# ---- Azure AI Search (RAG vector store) ----
AZURE_SEARCH_ENDPOINT=
AZURE_SEARCH_KEY=

# ---- GitHub (PRs, commits, file contents) ----
GITHUB_TOKEN=
