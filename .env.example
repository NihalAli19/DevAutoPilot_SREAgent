# DevAutoPilot v2 — environment configuration (placeholders only, no real secrets)
# Copy this file to .env and fill in values. NEVER commit a real .env.

# ---- LLM providers ----
# OpenAI (embeddings / fallback codegen)
OPENAI_API_KEY=

# Azure OpenAI (heavy reasoning — RCA, patch synthesis)
AZURE_OPENAI_ENDPOINT=
AZURE_OPENAI_API_KEY=

# Google Gemini Flash (free cloud reasoning path)
GEMINI_API_KEY=

# Ollama (local LLM path — default in dev)
OLLAMA_BASE_URL=http://localhost:11434

# ---- Data layer ----
# PostgreSQL (async asyncpg driver)
DATABASE_URL=postgresql+asyncpg://devautopilot:devautopilot@localhost:5432/devautopilot

# ---- Azure AI Search (RAG vector store) ----
AZURE_SEARCH_ENDPOINT=
AZURE_SEARCH_KEY=

# ---- GitHub (PRs, commits, file contents) ----
GITHUB_TOKEN=
